{
  "name": "hubble-ui",
  "private": true,
  "scripts": {
    "test": "jest",
    "postinstall": "patch-package && bash ./scripts/post-install.sh",
    "watch:server": "servor ./server/public index.html 8080",
    "watch:client": "NODE_ENV=development webpack --progress",
    "watch": "run-p watch:*",
    "build": "NODE_ENV=production webpack",
    "prettier": "prettier --write .",
    "lint": "run-s lint:ts lint:scss",
    "lint:fix": "run-s lint:ts:fix lint:scss:fix",
    "lint:ts": "eslint --ignore-path .gitignore \"./**/*.{ts,tsx,js,jsx,mjs}\"",
    "lint:ts:fix": "npm run lint:ts -- --fix",
    "lint:scss": "stylelint --ignore-path .gitignore \"./**/*.scss\"",
    "lint:scss:fix": "npm run lint:scss -- --fix",
    "upgrade-deps": "ncu --interactive --format group"
  },
  "lint-staged": {
    "./src/!(proto)/**/*.{ts,tsx,js,jsx,mjs}": [
      "npm run --silent lint:ts:fix"
    ],
    "./src/**/*.scss": [
      "npm run --silent lint:scss:fix"
    ]
  },
  "config": {
    "protocVersion": "25.2"
  },
  "dependencies": {
    "@babel/runtime": "7.29.2",
    "@blueprintjs/core": "6.11.3",
    "@blueprintjs/icons": "6.8.0",
    "@blueprintjs/select": "6.1.8",
    "@improbable-eng/grpc-web": "0.15.0",
    "@react-hook/resize-observer": "2.0.2",
    "@react-spring/web": "10.0.3",
    "@use-gesture/react": "10.3.1",
    "classnames": "2.5.1",
    "core-js": "3.49.0",
    "d3": "7.9.0",
    "date-fns": "4.1.0",
    "decompress": "4.2.1",
    "google-protobuf": "3.21.4",
    "history": "5.3.0",
    "lodash": "4.17.23",
    "mobx": "6.15.0",
    "mobx-react": "9.2.1",
    "pluralize": "8.0.0",
    "prop-types": "15.8.1",
    "query-string": "9.3.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "7.14.0",
    "react-window": "1.8.11",
    "url-parse": "1.5.10"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/plugin-proposal-nullish-coalescing-operator": "7.18.6",
    "@babel/plugin-proposal-optional-chaining": "7.21.0",
    "@babel/plugin-transform-runtime": "7.29.0",
    "@babel/preset-env": "7.29.2",
    "@babel/preset-react": "7.28.5",
    "@blueprintjs/node-build-scripts": "9.3.3",
    "@protobuf-ts/plugin": "2.11.1",
    "@testing-library/react": "16.3.2",
    "@types/d3": "7.4.3",
    "@types/google-protobuf": "3.15.12",
    "@types/jest": "30.0.0",
    "@types/lodash": "4.17.24",
    "@types/object-hash": "3.0.6",
    "@types/pluralize": "0.0.33",
    "@types/prop-types": "15.7.15",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@types/react-test-renderer": "18.3.1",
    "@types/react-window": "1.8.8",
    "@types/route-parser": "0.1.7",
    "@types/url-parse": "1.4.11",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "ajv": "8.18.0",
    "autoprefixer": "10.4.27",
    "babel-jest": "30.3.0",
    "babel-loader": "10.1.1",
    "css-loader": "7.1.4",
    "dotenv-webpack": "8.1.1",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-unused-imports": "^4.3.0",
    "fs-extra": "11.3.4",
    "html-webpack-plugin": "5.6.6",
    "identity-obj-proxy": "3.0.0",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "lint-staged": "16.4.0",
    "mini-css-extract-plugin": "2.10.2",
    "node-fetch": "3.3.2",
    "npm-check-updates": "19.6.6",
    "npm-run-all": "4.1.5",
    "patch-package": "8.0.1",
    "prettier": "3.8.1",
    "react-test-renderer": "18.3.1",
